{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testMatch": ["<rootDir>/test/**/*.spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "src/**/*.{ts,js}",
    "!src/**/*.spec.ts",
    "!src/infrastructure/prisma/generated/**"
  ],
  "coverageDirectory": "<rootDir>/coverage",
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/test/setup-env.ts"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^@/(.*)$": "<rootDir>/src/$1"
  }
}
