# Postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=tutor_postgres
POSTGRES_PORT=5432
POSTGRES_DB=tutor
POSTGRES_URI='postgresql://admin:change_me@tutor_postgres:5432/tutor'

# Postgres Exporter — отдельная read-only роль (создаётся postgres/init-monitoring.sh)
POSTGRES_EXPORTER_PASSWORD=change_me

# Backend
PORT=5000

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_NAME=your_bot_name
TELEGRAM_ADMIN_ID=your_telegram_admin_id

# Auth
REFRESH_SECRET_KEY=change_me
REFRESH_EXPIRES_IN=1h

ACCESS_SECRET_KEY=change_me
ACCESS_EXPIRES_IN=5m

ADMIN_REGISTRATION_SECRET_KEY=change_me

# CORS — origin фронтенда (для docker: http://tutor_frontend:3000)
ORIGIN_URLS=http://tutor_frontend:3000


# Frontend — base URL бэкенда, вшивается в бандл, должен быть доступен из браузера
VITE_API_URL=http://localhost:5008/api
